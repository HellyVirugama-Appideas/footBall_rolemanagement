<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">

<head>
  <%- include('_layouts/head') %>
    <title>CV Search | <%= title %>
    </title>
    <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/css/jquery.dataTables.min.css">
    <link rel="stylesheet" type="text/css"
      href="/app-assets/vendors/data-tables/extensions/responsive/css/responsive.dataTables.min.css">
    <style>
      .search-card {
        border-radius: 12px;
      }

      .badge-skill {
        display: inline-block;
        background: #e8f5e9;
        color: #2e7d32;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        margin: 2px;
      }

      .badge-exp {
        display: inline-block;
        background: #e3f2fd;
        color: #1565c0;
        padding: 2px 10px;
        border-radius: 10px;
        font-size: 12px;
      }

      .cv-row:hover {
        background: #f3e5f5;
        cursor: pointer;
      }

      .result-count {
        color: #7c4dff;
        font-weight: bold;
        font-size: 1.1rem;
      }

      .action-btns a {
        margin: 0 3px;
      }

      /* ── Filter Toggle ── */
      .filter-toggle-btn {
        background: #f8f5ff;
        border: 1.5px solid #7c4dff;
        color: #7c4dff;
        border-radius: 8px;
        padding: 8px 20px;
        cursor: pointer;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
      }

      .filter-toggle-btn:hover {
        background: #ede7f6;
      }

      .filter-toggle-btn .arrow {
        transition: transform 0.3s;
        display: inline-block;
      }

      .filter-toggle-btn.open .arrow {
        transform: rotate(180deg);
      }

      /* Active filters summary */
      .active-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 8px;
      }

      .filter-tag {
        background: #ede7f6;
        color: #512da8;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .filter-tag .remove {
        cursor: pointer;
        font-weight: bold;
        color: #7c4dff;
      }

      /* Filter panel */
      .filter-panel {
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transition: all 0.35s ease;
        padding: 0 4px;
      }

      .filter-panel.open {
        max-height: 700px;
        opacity: 1;
        padding: 16px 4px 4px;
      }

      .search-card .card-content {
        overflow: visible;
      }

      .table-responsive-wrapper {
        width: 100%;
        overflow-x: auto;
      }

      /* Search history dropdown */
      .search-history-wrap {
        position: relative;
        z-index: 9999;
        overflow: visible !important;
      }

      .history-dropdown {
        position: fixed;
        background: #fff;
        border-radius: 10px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.15);
        z-index: 999999;
        max-height: 220px;
        overflow-y: auto;
        overflow-x: hidden;
        display: none;
        width: 320px;
      }


      .history-item {
        padding: 10px 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        border-bottom: 1px solid #f3f3f3;
        background: #fff;
      }

      .history-item:hover {
        background: #f8f5ff;
      }

      .history-item .hist-text {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .history-item .hist-remove {
        margin-left: 10px;
        color: #999;
      }

      .history-header {
        position: sticky;
        top: 0;
        background: #fff;
        padding: 8px 14px;
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #eee;
        z-index: 2;
      }


      /*  */

      /* Table Improvements */
      .table-responsive-wrapper {
        overflow-x: auto;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 2px;
        background: white;
      }

      .table-responsive-wrapper table th {
        background: #f8f5ff !important;
        color: #512da8;
        font-weight: 500;
        padding: 14px 8px;
        white-space: nowrap;
      }

      .table-responsive-wrapper table td {
        padding: 14px 8px;
        vertical-align: middle;
      }

      .cv-row {
        transition: all 0.25s ease;
      }

      .cv-row:hover {
        background: #f3e5f5 !important;
        transform: scale(1.01);
      }

      .action-btns a {
        display: inline-block;
        padding: 6px;
        border-radius: 50%;
        transition: all 0.2s;
      }

      .action-btns a:hover {
        background: rgba(124, 77, 255, 0.15);
      }

      /* Scrollbar Styling */
      .table-responsive-wrapper::-webkit-scrollbar {
        height: 9px;
      }

      .table-responsive-wrapper::-webkit-scrollbar-thumb {
        background: gray;
        border-radius: 10px;
      }
    </style>
</head>

<body
  class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns"
  data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

  <%- include('_layouts/sidenavbar') %>

    <div id="main">
      <div class="row">
        <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
          <div class="container">
            <div class="row">
              <div class="col s12 m6 l6">
                <h5 class="breadcrumbs-title mt-0 mb-0">
                  <a class="mr-2" href="/cv-upload"><i class="material-icons">arrow_back</i></a>
                  <span>CV Search</span>
                </h5>
              </div>
              <div class="col s12 m6 l6 right-align-md">
                <a href="/cv-upload" class="btn gradient-45deg-purple-deep-orange btn-breadcrumbs">
                  <i class="material-icons left">cloud_upload</i> Upload More
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="col s12">
          <div class="container">
            <%- messages('messages', locals) %>

              <!-- ── Search & Filter Card ── -->
              <div class="card search-card">
                <div class="card-content">

                  <!-- Toggle button row -->
                  <div
                    style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;">
                    <button type="button" class="filter-toggle-btn" id="filterToggleBtn" onclick="toggleFilter()">
                      <i class="material-icons" style="font-size:18px;">tune</i>
                      Search & Filter CVs
                      <span class="arrow">▼</span>
                    </button>

                    <!-- Active filter tags (shown when panel is closed) -->
                    <div class="active-filters" id="activeFilterTags"></div>

                    <% var hasFilters=query.search || query.skill || query.minExp || query.maxExp || query.city; %>
                      <% if (hasFilters) { %>
                        <a href="/cv-search" class="btn-flat grey-text" style="font-size:13px;">
                          <i class="material-icons left tiny">clear</i> Clear all
                        </a>
                        <% } %>
                  </div>

                  <!-- Collapsible filter panel -->
                  <div class="filter-panel" id="filterPanel">
                    <form method="GET" action="/cv-search" id="searchForm" onsubmit="saveSearchHistory()">
                      <div class="row" style="margin-bottom:0; margin-top:8px;">

                        <!-- Search with history -->
                        <div class="col s12 m4">
                          <div class="input-field search-history-wrap">
                            <i class="material-icons prefix">search</i>
                            <input type="text" id="search" name="search" value="<%= query.search || '' %>"
                              placeholder="Name, email, or keyword..." autocomplete="off" onfocus="showHistory()"
                              oninput="filterHistory(this.value)" onblur="setTimeout(hideHistory, 200)">
                            <label for="search" class="<%= query.search ? 'active' : '' %>">Search (Name / Email /
                              Keyword)</label>
                            <div class="history-dropdown" id="historyDropdown"></div>
                          </div>
                        </div>

                        <div class="col s12 m3">
                          <div class="input-field">
                            <i class="material-icons prefix">star</i>
                            <input type="text" id="skill" name="skill" value="<%= query.skill || '' %>"
                              placeholder="e.g. React, Scouting...">
                            <label for="skill" class="<%= query.skill ? 'active' : '' %>">Skill</label>
                          </div>
                        </div>

                        <div class="col s12 m2">
                          <div class="input-field">
                            <i class="material-icons prefix">timeline</i>
                            <input type="number" id="minExp" name="minExp" min="0" max="50"
                              value="<%= query.minExp || '' %>" placeholder="0">
                            <label for="minExp" class="<%= query.minExp ? 'active' : '' %>">Min Exp (Yrs)</label>
                          </div>
                        </div>

                        <div class="col s12 m2">
                          <div class="input-field">
                            <i class="material-icons prefix">timeline</i>
                            <input type="number" id="maxExp" name="maxExp" min="0" max="50"
                              value="<%= query.maxExp || '' %>" placeholder="50">
                            <label for="maxExp" class="<%= query.maxExp ? 'active' : '' %>">Max Exp (Yrs)</label>
                          </div>
                        </div>

                        <div class="col s12 m1" style="padding-top:20px;">
                          <button type="submit" class="btn gradient-45deg-purple-deep-orange btn-block">
                            <i class="material-icons">search</i>
                          </button>
                        </div>
                      </div>

                      <div class="row" style="margin-bottom:0;">
                        <div class="col s12 m4">
                          <div class="input-field">
                            <i class="material-icons prefix">location_on</i>
                            <input type="text" id="city" name="city" value="<%= query.city || '' %>"
                              placeholder="e.g. London, Milan...">
                            <label for="city" class="<%= query.city ? 'active' : '' %>">City / Location</label>
                          </div>
                        </div>
                        <div class="col s12 m4" style="padding-top:20px;">
                          <a href="/cv-search" class="btn gradient-45deg-purple-deep-orange btn-block">
                            <i class="material-icons left">clear</i> Clear Filters
                          </a>
                        </div>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

              <!-- ── Results ── -->
              <!-- ── Results ── -->
              <div class="card">
                <div class="card-content">
                  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                    <span class="result-count">
                      <%= total %> Candidates Found
                    </span>
                    <a href="/cv-upload" class="btn-flat purple-text">
                      <i class="material-icons left">cloud_upload</i>Upload More CVs
                    </a>
                  </div>

                  <% if (cvs.length===0) { %>
                    <div style="text-align:center; padding:40px;">
                      <i class="material-icons" style="font-size:60px; color:#ccc;">description</i>
                      <p class="grey-text">No CVs found. Try different search terms or upload more CVs.</p>
                      <a href="/cv-upload" class="btn gradient-45deg-purple-deep-orange">Upload CVs</a>
                    </div>
                    <% } else { %>

                      <!-- Improved Scrollable Table -->
                      <div class="table-responsive-wrapper">
                        <table class="striped highlight" id="cvTable" style="min-width: 1200px; width: 100%;">
                          <thead>
                            <tr>
                              <th width="50">Sr</th>
                              <th width="180">Name</th>
                              <th width="220">Email</th>
                              <th width="200">Skills</th>
                              <th width="120">Experience</th>
                              <th width="140">City</th>
                              <th width="110">Status</th>
                              <th width="150">Actions</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% for (let i=0; i < cvs.length; i++) { %>
                              <tr class="cv-row">
                                <td>
                                  <%= (currentPage - 1) * 20 + i + 1 %>
                                </td>
                                <td>
                                  <strong>
                                    <%= cvs[i].name || '—' %>
                                  </strong>
                                  <br><small class="grey-text" style="font-size:12px;">
                                    <%= cvs[i].originalFileName %>
                                  </small>
                                </td>
                                <td style="font-size:13.5px; word-break: break-all;">
                                  <%= cvs[i].email || '—' %>
                                </td>
                                <td>
                                  <% if (cvs[i].skills && cvs[i].skills.length> 0) { %>
                                    <% cvs[i].skills.slice(0,3).forEach(function(s){ %>
                                      <span class="badge-skill">
                                        <%= s %>
                                      </span>
                                      <% }) %>
                                        <% if (cvs[i].skills.length> 3) { %>
                                          <span class="grey-text">+<%= cvs[i].skills.length - 3 %></span>
                                          <% } %>
                                            <% } else { %>
                                              <span class="grey-text">—</span>
                                              <% } %>
                                </td>
                                <td>
                                  <% if (cvs[i].experience && cvs[i].experience !=='Fresher' ) { %>
                                    <span class="badge-exp">
                                      <%= cvs[i].experience %>
                                    </span>
                                    <% } else { %>
                                      <span class="grey-text">
                                        <%= cvs[i].experience || '—' %>
                                      </span>
                                      <% } %>
                                </td>
                                <td>
                                  <%= cvs[i].city || '—' %>
                                </td>
                                <td>
                                  <% if (cvs[i].status==='processed' ) { %>
                                    <span class="chip green white-text">Processed</span>
                                    <% } else if (cvs[i].status==='failed' ) { %>
                                      <span class="chip red white-text">Failed</span>
                                      <% } else { %>
                                        <span class="chip orange white-text">Pending</span>
                                        <% } %>
                                          <% if (cvs[i].userId) { %>
                                            <br><span class="chip green lighten-4 green-text" style="font-size:10px;">In
                                              Users</span>
                                            <% } %>
                                </td>
                                <td class="action-btns" style="text-align:center; white-space:nowrap;">
                                  <a href="/cv-view/<%= cvs[i]._id %>" title="View" style="margin:0 5px;">
                                    <i class="material-icons" style="color:#7c4dff; font-size:24px;">visibility</i>
                                  </a>
                                  <a href="/cv-download/<%= cvs[i]._id %>" title="Download" style="margin:0 5px;">
                                    <i class="material-icons style=" color:#4caf50 !important;
                                      font-size:24px;">file_download</i>
                                  </a>
                                  <% if (typeof can === 'function' && can('cvSearch', 'edit')) { %>
                                  <a href="/cv-edit/<%= cvs[i]._id %>" title="Edit" style="margin:0 5px;">
                                    <i class="material-icons" style="color:#ff9800; font-size:24px;">edit</i>
                                  </a>
                                  <% } %>
                                  <% if (cvs[i].userId) { %>
                                    <a href="/user/<%= cvs[i].userId %>" title="User Profile" style="margin:0 5px;">
                                      <i class="material-icons" style="color:#2196f3; font-size:24px;">person</i>
                                    </a>
                                    <% } %>
                                      <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                                      <a href="/cv-delete/<%= cvs[i]._id %>" onclick="return confirm('Delete this CV?')"
                                        title="Delete" style="margin:0 5px;">
                                        <i class="material-icons red-text" style="font-size:24px;">delete</i>
                                      </a>
                                      <% } %>
                                </td>
                              </tr>
                              <% } %>
                          </tbody>
                        </table>
                      </div>

                      <!-- Pagination -->
                      <% if (totalPages> 1) { %>
                        <div style="text-align:center; margin-top:25px;">
                          <ul class="pagination">
                            <% if (currentPage> 1) { %>
                              <li class="waves-effect"><a
                                  href="/cv-search?<%= new URLSearchParams({...query, page: currentPage-1}).toString() %>"><i
                                    class="material-icons">chevron_left</i></a></li>
                              <% } %>
                                <% for (let p=Math.max(1, currentPage-2); p <=Math.min(totalPages, currentPage+2); p++)
                                  { %>
                                  <li class="<%= p === currentPage ? 'active purple' : 'waves-effect' %>">
                                    <a href="/cv-search?<%= new URLSearchParams({...query, page: p}).toString() %>">
                                      <%= p %>
                                    </a>
                                  </li>
                                  <% } %>
                                    <% if (currentPage < totalPages) { %>
                                      <li class="waves-effect"><a
                                          href="/cv-search?<%= new URLSearchParams({...query, page: currentPage+1}).toString() %>"><i
                                            class="material-icons">chevron_right</i></a></li>
                                      <% } %>
                          </ul>
                        </div>
                        <% } %>

                          <% } %>
                </div>
              </div>

          </div>
          <div class="content-overlay"></div>
        </div>
      </div>
    </div>

    <%- include('_layouts/commonJs') %>

      <script>
        // ────────────────────────────────────────
        // FILTER TOGGLE
        // ────────────────────────────────────────
        var filterOpen = false;

        // Auto-open if any filter is active
        var hasActiveFilter = <%= (query.search || query.skill || query.minExp || query.maxExp || query.city) ? 'true' : 'false' %>;
        if (hasActiveFilter) {
          filterOpen = true;
          document.getElementById('filterPanel').classList.add('open');
          document.getElementById('filterToggleBtn').classList.add('open');
        }

        function toggleFilter() {
          filterOpen = !filterOpen;
          var panel = document.getElementById('filterPanel');
          var btn = document.getElementById('filterToggleBtn');
          if (filterOpen) {
            panel.classList.add('open');
            btn.classList.add('open');
          } else {
            panel.classList.remove('open');
            btn.classList.remove('open');
          }
        }

        // Show active filter tags outside the panel
        function renderFilterTags() {
          var tags = document.getElementById('activeFilterTags');
          tags.innerHTML = '';
          var filters = [
            { key: 'search', label: 'Search', val: '<%= query.search || "" %>' },
            { key: 'skill', label: 'Skill', val: '<%= query.skill  || "" %>' },
            { key: 'city', label: 'City', val: '<%= query.city   || "" %>' },
            { key: 'minExp', label: 'Min Exp', val: '<%= query.minExp || "" %>' },
            { key: 'maxExp', label: 'Max Exp', val: '<%= query.maxExp || "" %>' },
          ];
          filters.forEach(function (f) {
            if (f.val) {
              var t = document.createElement('span');
              t.className = 'filter-tag';
              t.innerHTML = f.label + ': <strong>' + f.val + '</strong>';
              tags.appendChild(t);
            }
          });
        }
        renderFilterTags();

        // ────────────────────────────────────────
        // SEARCH HISTORY (localStorage)
        // ────────────────────────────────────────
        var HISTORY_KEY = 'cvSearchHistory';
        var MAX_HISTORY = 15;

        function getHistory() {
          try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); }
          catch (e) { return []; }
        }

        function saveHistory(arr) {
          localStorage.setItem(HISTORY_KEY, JSON.stringify(arr));
        }

        function saveSearchHistory() {
          var val = document.getElementById('search').value.trim();
          if (!val) return;
          var hist = getHistory().filter(function (h) { return h !== val; });
          hist.unshift(val);
          if (hist.length > MAX_HISTORY) hist = hist.slice(0, MAX_HISTORY);
          saveHistory(hist);
        }

        function showHistory() {
          var val = document.getElementById('search').value.trim();
          renderHistoryDropdown(val);
          document.getElementById('historyDropdown').style.display = 'block';
        }

        function hideHistory() {
          document.getElementById('historyDropdown').style.display = 'none';
        }

        function filterHistory(val) {
          renderHistoryDropdown(val);
          document.getElementById('historyDropdown').style.display = 'block';
        }

        function renderHistoryDropdown(filter) {
          var drop = document.getElementById('historyDropdown');
          var hist = getHistory();
          if (filter) {
            hist = hist.filter(function (h) {
              return h.toLowerCase().includes(filter.toLowerCase());
            });
          }
          if (!hist.length) { drop.innerHTML = ''; drop.style.display = 'none'; return; }

          var html = '<div class="history-header">';
          html += '<span>Recent searches</span>';
          html += '<span class="clear-all-hist" onclick="clearAllHistory()">Clear all</span>';
          html += '</div>';

          hist.forEach(function (h, idx) {
            html += '<div class="history-item" onclick="selectHistory(\'' + h.replace(/'/g, "\\'") + '\')">';
            html += '<span class="hist-text"><i class="material-icons" style="font-size:15px;color:#bbb;">history</i>' + h + '</span>';
            html += '<span class="hist-remove" onclick="removeHistory(event,' + idx + ')">×</span>';
            html += '</div>';
          });

          drop.innerHTML = html;
        }

        function selectHistory(val) {
          document.getElementById('search').value = val;
          // Move label up
          var label = document.querySelector('label[for="search"]');
          if (label) label.classList.add('active');
          hideHistory();
        }

        function removeHistory(e, idx) {
          e.stopPropagation();
          var hist = getHistory();
          hist.splice(idx, 1);
          saveHistory(hist);
          renderHistoryDropdown(document.getElementById('search').value);
        }

        function clearAllHistory() {
          saveHistory([]);
          hideHistory();
        }

        // Save history on form submit
        document.getElementById('searchForm').addEventListener('submit', function () {
          saveSearchHistory();
        });

        // Also save when user presses Enter in search field
        document.getElementById('search').addEventListener('keydown', function (e) {
          if (e.key === 'Enter') saveSearchHistory();
        });
      </script>
</body>

</html>