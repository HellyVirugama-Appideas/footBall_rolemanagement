<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">

<head>
  <%- include('_layouts/head') %>
    <title>CV Detail | <%= title %>
    </title>
    <style>
      .detail-card {
        border-radius: 12px;
      }

      .info-row {
        padding: 10px 0;
        border-bottom: 1px solid #f5f5f5;
      }

      .info-label {
        color: #888;
        font-size: 13px;
      }

      .info-value {
        font-weight: 500;
      }

      .badge-skill {
        display: inline-block;
        background: #e8f5e9;
        color: #2e7d32;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 13px;
        margin: 3px;
      }

      .badge-title {
        display: inline-block;
        background: #e3f2fd;
        color: #1565c0;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 13px;
        margin: 3px;
      }

      .raw-text-box {
        background: #f5f5f5;
        padding: 15px;
        border-radius: 8px;
        max-height: 300px;
        overflow-y: auto;
        font-family: monospace;
        font-size: 12px;
        white-space: pre-wrap;
        word-break: break-word;
      }
    </style>
</head>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">


<body
  class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns"
  data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

  <%- include('_layouts/sidenavbar') %>

    <div id="main">
      <div class="row">
        <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
          <div class="container">
            <div class="row">
              <div class="col s12 m6 l6">
                <h5 class="breadcrumbs-title mt-0 mb-0">
                  <a class="mr-2" href="/cv-search"><i class="material-icons">arrow_back</i></a>
                  <span>CV Detail</span>
                </h5>
              </div>
              <div class="col s12 m6 l6 right-align-md">
                <a href="/cv-download/<%= cv._id %>" class="btn gradient-45deg-purple-deep-orange btn-breadcrumbs">
                  <i class="material-icons left">download</i> Download CV
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="col s12">
          <div class="container">
            <%- messages('messages', locals) %>

              <div class="row">
                <!-- Main Info -->
                <div class="col s12 m8">
                  <div class="card detail-card">
                    <div class="card-content">
                      <span class="card-title" style="color:#7c4dff;">
                        <i class="material-icons left">person</i>
                        <%= cv.name || 'Unknown Candidate' %>
                      </span>

                      <div class="row" style="margin-bottom:0;">
                        <div class="col s12 m6">
                          <div class="info-row">
                            <div class="info-label">Email</div>
                            <div class="info-value">
                              <%= cv.email || '—' %>
                            </div>
                          </div>

                          <div class="info-row">
                            <div class="info-label">City</div>
                            <div class="info-value">
                              <%= cv.city || '—' %>
                            </div>
                          </div>
                        </div>
                        <div class="col s12 m6">
                          <div class="info-row">
                            <div class="info-label">Experience</div>
                            <div class="info-value">
                              <%= cv.experience || 'Not specified' %>
                            </div>
                          </div>
                          <div class="info-row">
                            <div class="info-label">File</div>
                            <div class="info-value" style="word-break:break-all;">
                              <%= cv.originalFileName %>
                            </div>
                          </div>
                          <div class="info-row">
                            <div class="info-label">Uploaded</div>
                            <div class="info-value">
                              <%= new Date(cv.date).toLocaleDateString('en-US', {year:'numeric', month:'short',
                                day:'numeric'}) %>
                            </div>
                          </div>
                        </div>
                      </div>

                      <% if (cv.summary) { %>
                        <div class="info-row" style="margin-top:10px;">
                          <div class="info-label">Summary</div>
                          <div class="info-value" style="margin-top:5px;">
                            <%= cv.summary %>
                          </div>
                        </div>
                        <% } %>

                          <% if (cv.skills && cv.skills.length> 0) { %>
                            <div style="margin-top:20px;">
                              <div class="info-label" style="margin-bottom:8px;">Skills Detected</div>
                              <% cv.skills.forEach(s=> { %>
                                <span class="badge-skill">
                                  <%= s %>
                                </span>
                                <% }) %>
                            </div>
                            <% } %>

                              <% if (cv.jobTitles && cv.jobTitles.length> 0) { %>
                                <div style="margin-top:15px;">
                                  <div class="info-label" style="margin-bottom:8px;">Job Roles Detected</div>
                                  <% cv.jobTitles.forEach(t=> { %>
                                    <span class="badge-title">
                                      <%= t %>
                                    </span>
                                    <% }) %>
                                </div>
                                <% } %>
                    </div>
                  </div>

                  <!-- Raw Text Preview -->
                  <% if (cv.rawText) { %>
                    <div class="card detail-card">
                      <div class="card-content">
                        <span class="card-title"><i class="material-icons left">subject</i>Extracted Text Preview</span>
                        <div class="raw-text-box">
                          <%= cv.rawText.slice(0, 2000) %>
                            <% if (cv.rawText.length> 2000) { %>
                              ... [truncated]<% } %>
                        </div>
                      </div>
                    </div>
                    <% } %>
                </div>

                <!-- Sidebar -->
                <div class="col s12 m4">
                  <!-- Status Card -->
                  <div class="card detail-card">
                    <div class="card-content">
                      <span class="card-title">Status</span>
                      <% if (cv.status==='processed' ) { %>
                        <div class="chip green white-text">✓ Processed</div>
                        <% } else if (cv.status==='failed' ) { %>
                          <div class="chip red white-text">✗ Failed</div>
                          <% if (cv.errorMessage) { %>
                            <p class="red-text">
                              <%= cv.errorMessage %>
                            </p>
                            <% } %>
                              <% } else { %>
                                <div class="chip orange white-text">⏳ Pending</div>
                                <% } %>

                                  <!-- <% if (cv.userId) { %>
                                    <div style="margin-top:15px;">
                                      <p class="green-text"><i class="material-icons tiny">check_circle</i> Linked to
                                        User</p>
                                      <a href="/user/<%= cv.userId._id || cv.userId %>" class="btn btn-small blue">
                                        <i class="material-icons left">person</i> View User Profile
                                      </a>
                                    </div>
                                    <% } else { %>
                                      <div style="margin-top:15px;">
                                        <p class="grey-text"><i class="material-icons tiny">info</i> Not linked to any
                                          user</p>
                                        <small class="grey-text">Email not found or already exists in system.</small>
                                      </div>
                                      <% } %> -->

                                  <% if (cv.userId) { %>
                                    <div style="margin-top:15px;">
                                      <p class="green-text"><i class="material-icons tiny">check_circle</i> Linked to
                                        User</p>

                                      <% const linkedinLink=(cv.userId && cv.userId.linkedinUrl) ? cv.userId.linkedinUrl
                                        : (cv.linkedinUrl) ? cv.linkedinUrl : null; %>

                                        <% if (linkedinLink) { %>
                                          <a href="<%= linkedinLink %>" target="_blank" rel="noopener noreferrer"
                                            class="btn btn-small blue" style="margin-bottom:8px;">
                                            <i class="material-icons left">open_in_new</i> View LinkedIn
                                          </a>
                                          <br>
                                          <% } %>

                                            <a href="/user/<%= cv.userId._id || cv.userId %>"
                                              class="btn btn-small grey darken-1">
                                              <i class="material-icons left">person</i> View User Profile
                                            </a>
                                    </div>
                                    <% } else { %>
                                      <div style="margin-top:15px;">
                                        <% if (cv.linkedinUrl) { %>
                                          <a href="<%= cv.linkedinUrl %>" target="_blank" rel="noopener noreferrer"
                                            class="btn btn-small blue">
                                            <i class="material-icons left">open_in_new</i> View LinkedIn
                                          </a>
                                          <% } else { %>
                                            <p class="grey-text"><i class="material-icons tiny">info</i> Not linked to
                                              any user</p>
                                            <small class="grey-text">Email not found or already exists in
                                              system.</small>
                                            <% } %>
                                      </div>
                                      <% } %>
                    </div>
                  </div>

                  <!-- Actions Card -->
                  <div class="card detail-card">
                    <div class="card-content">
                      <span class="card-title">Actions</span>
                      <div style="display:flex; flex-direction:column; gap:10px;">
                        <a href="/cv-download/<%= cv._id %>" class="btn green">
                          <i class="material-icons left">file_download</i> Download CV
                        </a>
                        <% if (typeof can === 'function' && can('cvSearch', 'edit')) { %>
                        <a href="/cv-edit/<%= cv._id %>" class="btn orange">
                          <i class="material-icons left">edit</i> Edit CV
                        </a>
                        <% } %>
                        <a href="/cv-search" class="btn blue">
                          <i class="material-icons left">arrow_back</i> Back to Search
                        </a>
                        <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                        <a href="/cv-delete/<%= cv._id %>"
                          onclick="return confirm('Are you sure you want to delete this CV?')" class="btn red">
                          <i class="material-icons left">delete</i> Delete CV
                        </a>
                        <% } %>
                      </div>
                    </div>
                  </div>

                  <!-- Batch Info -->
                  <% if (cv.batchId) { %>
                    <div class="card detail-card">
                      <div class="card-content">
                        <span class="card-title">Batch Info</span>
                        <p class="grey-text" style="font-size:12px;">Batch: <%= cv.batchId %>
                        </p>
                        <% if (cv.fileSize) { %>
                          <p class="grey-text" style="font-size:12px;">File size: <%= (cv.fileSize / 1024).toFixed(1) %>
                              KB</p>
                          <% } %>
                      </div>
                    </div>
                    <% } %>
                </div>
              </div>
          </div>
          <div class="content-overlay"></div>
        </div>
      </div>
    </div>

    <%- include('_layouts/commonJs') %>
</body>

</html>