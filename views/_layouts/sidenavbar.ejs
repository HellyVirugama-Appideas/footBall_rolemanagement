            <a class="waves-effect waves-cyan" href="/skill">
                <i class="material-icons">star</i>
                <span class="menu-title">Job Skill</span>
            </a>
        </li>
        <% } %>

        <% if (typeof can !== 'function' || can('testimonials', 'view')) { %>
        <li class="bold <%= url.startsWith('/testimonial') ? 'active' : '' %>">
            <a class="waves-effect waves-cyan" href="/testimonial">
                <i class="material-icons">picture_in_picture</i>
