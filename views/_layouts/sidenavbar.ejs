<!-- BEGIN: Header -->
<header class="page-topbar" id="header" style="margin-top: -22px;">
    <div class="navbar navbar-fixed">
        <nav class="navbar-main navbar-color nav-collapsible sideNav-lock navbar-light">
            <div class="nav-wrapper">
                <ul class="navbar-list right">
                    <li>
                        <a class="waves-effect waves-block waves-light profile-button" href="javascript:void(0);"
                            data-target="profile-dropdown">
                            <span class="avatar-status">
                                <% if (typeof photo !== 'undefined') { %>
                                    <img src="<%= photo %>" alt="avatar"
                                        onerror="this.onerror=null; this.src='/uploads/default_user.jpg';">
                                <% } else { %>
                                    <img src="/uploads/default_user.jpg" alt="avatar">
                                <% } %>
                            </span>
                        </a>
                    </li>
                </ul>
                <ul class="dropdown-content" id="profile-dropdown">
                    <li><a class="grey-text text-darken-1" href="/profile"><i class="material-icons">person_outline</i>Profile</a></li>
                    <li><a class="grey-text text-darken-1" href="/changepass"><i class="material-icons">lock_outline</i>Change Password</a></li>
                    <li><a class="grey-text text-darken-1" href="/logout" onclick="return confirm('Are you sure?');"><i class="material-icons">keyboard_tab</i>Logout</a></li>
                </ul>
            </div>
        </nav>
    </div>
</header>
<!-- END: Header-->

<!-- BEGIN: SideNav-->
<aside class="sidenav-main nav-expanded nav-lock nav-collapsible sidenav-dark sidenav-active-rounded">
    <div class="brand-sidebar" style="background: white;">
        <h1 class="logo-wrapper">
            <a class="brand-logo darken-1" href="/">
                <img class="hide-on-med-and-down" src="/app-assets/images/logo/logo.png" alt="logo">
            </a>
        </h1>
    </div>

    <ul class="sidenav sidenav-collapsible leftside-navigation collapsible sidenav-fixed menu-shadow" id="slide-out"
        data-menu="menu-navigation" data-collapsible="accordion">

        <!-- ==================== DEBUG SCRIPT ==================== -->
        <script>
            console.log("=== DEBUG PERMISSION CHECK ===");
            console.log("isSuperAdmin:", <%= isSuperAdmin ? 'true' : 'false' %>);
            console.log("Can users.view?", <%= typeof can === 'function' ? can('users', 'view') : false %>);
            console.log("Can candidates.view?", <%= typeof can === 'function' ? can('candidates', 'view') : false %>);
            console.log("Role Data:", <%- JSON.stringify(currentAdmin?.role || null) %>);
        </script>
        <!-- ==================== DEBUG SCRIPT END ==================== -->

        <li class="bold <%= url == '/' ? 'active' : '' %>">
            <a class="waves-effect waves-cyan <%= url == '/' ? 'active' : '' %>" href="/">
                <i class="material-icons">desktop_windows</i>
                <span class="menu-title">Dashboard</span>
            </a>
        </li>

        <li class="navigation-header">
            <a class="navigation-header-text">manage</a>
            <i class="navigation-header-icon material-icons">more_horiz</i>
        </li>

        <% if (typeof can !== 'function' || can('cms', 'view')) { %>
        <li class="bold <%= url.startsWith('/cms') ? 'active' : '' %>">
            <a class="collapsible-header waves-effect waves-cyan" href="javascript:void(0);">
                <i class="material-icons">content_paste</i>
                <span class="menu-title">Content Pages</span>
            </a>
            <div class="collapsible-body">
                <ul class="collapsible collapsible-sub" data-collapsible="accordion">
                    <li><a href="/cms/whoWeAre">Who We Are</a></li>
                    <li><a href="/cms/privacy">Privacy notice</a></li>
                    <li><a href="/cms/terms">Terms & Conditions</a></li>
                </ul>
            </div>
        </li>
        <% } %>

        <% if (typeof can !== 'function' || can('banners', 'view')) { %>
        <li class="bold <%= url.startsWith('/banner') ? 'active' : '' %>">
            <a class="waves-effect waves-cyan" href="/banner">
                <i class="material-icons">collections</i>
                <span class="menu-title">Banners</span>
            </a>
        </li>
        <% } %>

        <% if (typeof can !== 'function' || can('recruiters', 'view')) { %>
        <li class="bold <%= url.startsWith('/recruiter') ? 'active' : '' %>">
            <a class="waves-effect waves-cyan" href="/recruiter">
                <i class="material-icons">add_circle_outline</i>
                <span class="menu-title">Recruiter</span>
            </a>
        </li>
        <% } %>

        <% if (typeof can !== 'function' || can('categories', 'view')) { %>
